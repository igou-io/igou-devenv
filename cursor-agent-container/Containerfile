ARG UBI_IMAGE=registry.access.redhat.com/ubi10/ubi:latest@sha256:c9c81d3d11bfd56c4bb61a220d4598392b5fbc500df33f2b8e52fdd2cebb4944
ARG UBI_IMAGE_MICRO=registry.access.redhat.com/ubi10/ubi-micro:latest@sha256:f86852f349dcd2b9ebccef4c8a46fdb75ff2fef9fde8581cef1feddb706be7ba

FROM ${UBI_IMAGE_MICRO} AS target

# ---------------------------------------------------------------------------
# Build stage — install everything into ubi-micro rootfs
# ---------------------------------------------------------------------------
FROM ${UBI_IMAGE} AS build

ARG DNF_INSTALL_ROOT="/mnt/rootfs"
ARG DNF_OPTS="--setopt install_weak_deps=false --nodocs"
ARG DNF_OPTS_ROOT="-y --installroot ${DNF_INSTALL_ROOT}"

RUN mkdir -p ${DNF_INSTALL_ROOT}
COPY --from=target / ${DNF_INSTALL_ROOT}/

# Build dependencies (not installed into rootfs)
RUN dnf install -y unzip xz tar gzip

# ---------------------------------------------------------------------------
# System packages into rootfs
# ---------------------------------------------------------------------------
RUN dnf ${DNF_OPTS_ROOT} ${DNF_OPTS} --skip-broken install \
    bash \
    coreutils \
    curl \
    tar \
    gzip \
    xz \
    unzip \
    findutils \
    git \
    jq \
    make \
    tree \
    openssh-clients \
    iputils \
    bind-utils \
    file \
    rsync \
    nmap \
    nmap-ncat \
    socat \
    iproute \
    python3 \
    python3-pip \
    python3-netaddr \
    which \
    procps-ng \
    && dnf ${DNF_OPTS_ROOT} clean all \
    && rm -rf ${DNF_INSTALL_ROOT}/var/cache/* ${DNF_INSTALL_ROOT}/var/log/dnf* ${DNF_INSTALL_ROOT}/var/log/yum.*

RUN mkdir -p ${DNF_INSTALL_ROOT}/usr/local/bin

# ---------------------------------------------------------------------------
# CLI tools — pinned versions managed by Renovate
# ---------------------------------------------------------------------------

# renovate: datasource=github-releases depName=kubernetes/kubernetes
ARG KUBECTL_VERSION="v1.35.3"
# renovate: datasource=github-releases depName=helm/helm
ARG HELM_VERSION="v4.1.3"
# renovate: datasource=github-releases depName=cli/cli
ARG GH_VERSION="v2.88.1"
# renovate: datasource=github-releases depName=argoproj/argo-cd
ARG ARGOCD_VERSION="v3.3.4"
# renovate: datasource=github-releases depName=kubernetes-sigs/kustomize extractVersion=^kustomize/(?<version>.*)$
ARG KUSTOMIZE_VERSION="v5.8.1"
# renovate: datasource=github-releases depName=kubevirt/kubevirt
ARG VIRTCTL_VERSION="v1.7.2"
# renovate: datasource=github-releases depName=yannh/kubeconform
ARG KUBECONFORM_VERSION="v0.7.0"
# renovate: datasource=github-releases depName=tektoncd/cli
ARG TKN_VERSION="v0.44.0"
# renovate: datasource=github-releases depName=rclone/rclone
ARG RCLONE_VERSION="v1.73.2"
# renovate: datasource=github-releases depName=containers/kubernetes-mcp-server
ARG K8S_MCP_VERSION="v0.0.59"

# ---------------------------------------------------------------------------
# Binary downloads into rootfs
# ---------------------------------------------------------------------------
RUN set -eux; \
    UARCH=$(uname -m); \
    case "$UARCH" in x86_64) ARCH=amd64;; aarch64) ARCH=arm64;; *) ARCH=$UARCH;; esac; \
    ARCH_X86=$([ "$ARCH" = "amd64" ] && echo "x86_64" || echo "$ARCH"); \
    ARCH_GNU=$UARCH; \
    BIN=${DNF_INSTALL_ROOT}/usr/local/bin; \
    # kubectl
    curl -sSL -o ${BIN}/kubectl \
      "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${ARCH}/kubectl" && \
    chmod +x ${BIN}/kubectl; \
    # helm
    curl -sSL "https://get.helm.sh/helm-${HELM_VERSION}-linux-${ARCH}.tar.gz" \
      | tar -xz --strip-components=1 -C ${BIN} "linux-${ARCH}/helm"; \
    # gh CLI
    GH_VERSION_BARE="${GH_VERSION#v}"; \
    curl -sSL "https://github.com/cli/cli/releases/download/${GH_VERSION}/gh_${GH_VERSION_BARE}_linux_${ARCH}.tar.gz" \
      | tar -xz --strip-components=2 -C ${BIN} "gh_${GH_VERSION_BARE}_linux_${ARCH}/bin/gh"; \
    # ArgoCD
    curl -sSL -o ${BIN}/argocd \
      "https://github.com/argoproj/argo-cd/releases/download/${ARGOCD_VERSION}/argocd-linux-${ARCH}" && \
    chmod +x ${BIN}/argocd; \
    # kustomize
    curl -sSL "https://github.com/kubernetes-sigs/kustomize/releases/download/kustomize%2F${KUSTOMIZE_VERSION}/kustomize_${KUSTOMIZE_VERSION}_linux_${ARCH}.tar.gz" \
      | tar -xz -C ${BIN} kustomize; \
    # OpenShift CLI (oc)
    curl -sSL "https://mirror.openshift.com/pub/openshift-v4/${ARCH_X86}/clients/ocp/latest/openshift-client-linux.tar.gz" \
      | tar -xz -C ${BIN} oc; \
    # virtctl
    curl -sSL -o ${BIN}/virtctl \
      "https://github.com/kubevirt/kubevirt/releases/download/${VIRTCTL_VERSION}/virtctl-${VIRTCTL_VERSION}-linux-${ARCH}" && \
    chmod +x ${BIN}/virtctl; \
    # kubeconform
    curl -sSL "https://github.com/yannh/kubeconform/releases/download/${KUBECONFORM_VERSION}/kubeconform-linux-${ARCH}.tar.gz" \
      | tar -xz -C ${BIN} kubeconform; \
    # tkn (Tekton CLI)
    TKN_VERSION_BARE="${TKN_VERSION#v}"; \
    curl -sSL "https://github.com/tektoncd/cli/releases/download/${TKN_VERSION}/tkn_${TKN_VERSION_BARE}_Linux_${ARCH_GNU}.tar.gz" \
      | tar -xz -C ${BIN} tkn; \
    # mc (MinIO client — rolling release, no version pin)
    curl -sSL -o ${BIN}/mc "https://dl.min.io/client/mc/release/linux-${ARCH}/mc" && \
    chmod +x ${BIN}/mc; \
    # rclone
    curl -sSL -o /tmp/rclone.zip \
      "https://github.com/rclone/rclone/releases/download/${RCLONE_VERSION}/rclone-${RCLONE_VERSION}-linux-${ARCH}.zip" && \
    unzip -j /tmp/rclone.zip "rclone-${RCLONE_VERSION}-linux-${ARCH}/rclone" -d ${BIN} && \
    chmod +x ${BIN}/rclone && \
    rm /tmp/rclone.zip; \
    # kubernetes-mcp-server (standalone binary, no npm/node needed)
    curl -sSL -o ${BIN}/kubernetes-mcp-server \
      "https://github.com/containers/kubernetes-mcp-server/releases/download/${K8S_MCP_VERSION}/kubernetes-mcp-server-linux-${ARCH}" && \
    chmod +x ${BIN}/kubernetes-mcp-server

# ---------------------------------------------------------------------------
# Python packages via chroot into rootfs
# ---------------------------------------------------------------------------
COPY requirements.txt ${DNF_INSTALL_ROOT}/tmp/requirements.txt
RUN cp /etc/resolv.conf ${DNF_INSTALL_ROOT}/etc/resolv.conf && \
    chroot ${DNF_INSTALL_ROOT} pip3 install --no-cache-dir -r /tmp/requirements.txt && \
    chroot ${DNF_INSTALL_ROOT} pip3 install --no-cache-dir yamllint && \
    rm ${DNF_INSTALL_ROOT}/tmp/requirements.txt && \
    rm -f ${DNF_INSTALL_ROOT}/usr/bin/pip ${DNF_INSTALL_ROOT}/usr/bin/pip3 \
          ${DNF_INSTALL_ROOT}/usr/local/bin/pip ${DNF_INSTALL_ROOT}/usr/local/bin/pip3 \
          ${DNF_INSTALL_ROOT}/usr/bin/ansible-galaxy \
          ${DNF_INSTALL_ROOT}/usr/local/bin/ansible-galaxy && \
    rm -rf ${DNF_INSTALL_ROOT}/usr/lib/python3.12/site-packages/pip \
           ${DNF_INSTALL_ROOT}/usr/share/python3-wheels \
           ${DNF_INSTALL_ROOT}/usr/share/cracklib

# ---------------------------------------------------------------------------
# User setup in rootfs
# ---------------------------------------------------------------------------
RUN echo "igou:x:1000:1000::/home/igou:/bin/bash" >> ${DNF_INSTALL_ROOT}/etc/passwd && \
    echo "igou:x:1000:" >> ${DNF_INSTALL_ROOT}/etc/group && \
    mkdir -p ${DNF_INSTALL_ROOT}/home/igou/.config/cursor && \
    chown -R 1000:1000 ${DNF_INSTALL_ROOT}/home/igou

# ---------------------------------------------------------------------------
# Cursor Agent CLI — install in build env, copy to rootfs
# ---------------------------------------------------------------------------
RUN groupadd -g 1000 igou 2>/dev/null || true && \
    useradd -m -u 1000 -g 1000 igou 2>/dev/null || true
USER 1000
RUN curl -fsSL https://cursor.com/install | bash && \
    ~/.local/bin/agent --version
USER root
RUN mkdir -p ${DNF_INSTALL_ROOT}/home/igou/.local && \
    cp -a /home/igou/.local/bin /home/igou/.local/share \
      ${DNF_INSTALL_ROOT}/home/igou/.local/ 2>/dev/null; \
    cp -a /home/igou/.local/bin \
      ${DNF_INSTALL_ROOT}/home/igou/.local/ && \
    chown -R 1000:1000 ${DNF_INSTALL_ROOT}/home/igou && \
    chmod 555 ${DNF_INSTALL_ROOT}/home/igou/.local/bin

# Entrypoint and baked Cursor sandbox config
COPY entrypoint.sh ${DNF_INSTALL_ROOT}/usr/local/bin/entrypoint.sh
RUN chmod +x ${DNF_INSTALL_ROOT}/usr/local/bin/entrypoint.sh
RUN mkdir -p ${DNF_INSTALL_ROOT}/etc/cursor
COPY sandbox.json ${DNF_INSTALL_ROOT}/etc/cursor/sandbox.json

# Workspace directory
RUN mkdir -p ${DNF_INSTALL_ROOT}/workspace && \
    chown 1000:1000 ${DNF_INSTALL_ROOT}/workspace

# ---------------------------------------------------------------------------
# Final minimal image
# ---------------------------------------------------------------------------
FROM scratch

ARG DNF_INSTALL_ROOT="/mnt/rootfs"
COPY --from=build ${DNF_INSTALL_ROOT}/ /

ENV HOME=/home/igou
ENV PATH="/home/igou/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ENV PYTHONNOUSERSITE=1
ENV PYTHONPATH="/usr/local/lib64/python3.12/site-packages:/usr/local/lib/python3.12/site-packages"
ENV PIP_NO_INPUT=1

WORKDIR /workspace
USER 1000

ENTRYPOINT ["entrypoint.sh"]
CMD ["agent"]
