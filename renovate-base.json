{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "automerge": true,
  "automergeType": "pr",
  "minimumReleaseAge": "10 days",
  "schedule": ["before 11pm on sunday"],
  "separateMajorMinor": false
}
