{
    "name": "igou-io Homelab",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    "features": {},
    "runArgs": [
        "--privileged",
        "--device=/dev/fuse",
        "--device=/dev/net/tun",
        "--network=host"
    ],
    "remoteUser": "igou",
    "containerUser": "igou",
    "containerEnv": {
        "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock",
        "HOME": "/home/igou",
        "CI": "${localEnv:CI}"
    },
    "remoteEnv": {
        "HOME": "/home/igou"
    },
    "initializeCommand": ".devcontainer/init.sh",
    "onCreateCommand": {
        "pip": "pip install --break-system-packages -r /workspace/igou-devenv/.devcontainer/requirements.txt"
    },
    "postCreateCommand": "/workspace/igou-devenv/.devcontainer/post-create.sh",
    "postStartCommand": "/workspace/igou-devenv/.devcontainer/post-start.sh",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/igou-devenv,type=bind",
    "workspaceFolder": "/workspace",
    "mounts": [
        "source=${localEnv:HOME}/.claude,target=/home/igou/.claude,type=bind",
        "source=${localEnv:HOME}/.claude.json,target=/home/igou/.claude.json,type=bind",
        "source=${localEnv:HOME}/.claude-container,target=/home/igou/.claude-container,type=bind",
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
        "source=${localEnv:HOME}/.gitconfig,target=/home/igou/.gitconfig,type=bind,readonly",
        "source=${localEnv:HOME}/.ssh,target=/home/igou/.ssh,type=bind,readonly",
        "source=${localEnv:HOME}/.kube,target=/home/igou/.kube,type=bind",
        "source=${localEnv:HOME}/.config/argocd,target=/home/igou/.config/argocd,type=bind",
        "source=${localEnv:HOME}/.terraform.d,target=/home/igou/.terraform.d,type=bind",
        "source=${localEnv:HOME}/.config/op,target=/home/igou/.config/op,type=bind,readonly",
        "source=${localEnv:HOME}/workspace,target=/workspace,type=bind",
        "source=${localEnv:HOME}/rosa-gitops,target=/workspace/rosa-gitops,type=bind",
        "source=${localEnv:HOME}/rosa-gitops-example-team,target=/workspace/rosa-gitops-example-team,type=bind"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "ansible.python.interpreterPath": "/usr/bin/python3",
                "files.trimTrailingWhitespace": true,
                "files.associations": {
                    "**/group_vars/**/*": "jinja-yaml",
                    "**/host_vars/**/*": "jinja-yaml",
                    "**/roles/**/*.yml": "ansible",
                    "**/playbooks/**/*.yml": "ansible",
                    "**/roles/**/*.yaml": "ansible",
                    "**/playbooks/**/*.yaml": "ansible",
                    "ansible.cfg": "ini",
                    "**/*.yaml": "yaml",
                    "**/*.yml": "yaml"
                },
                "yaml.schemas": {
                    "kubernetes": [
                        "igou-kubernetes/apps/**/*.yaml",
                        "igou-kubernetes/base/**/*.yaml",
                        "igou-kubernetes/bootstrap/**/*.yaml",
                        "igou-kubernetes/config/**/*.yaml"
                    ],
                    "https://squidfunk.github.io/mkdocs-material/schema.json": "mkdocs.yml"
                }
            }
        }
    }
}
