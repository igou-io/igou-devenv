# Build context spans the repo root so the Dockerfile can COPY
# mise.toml/mise.lock and the aqua-registry. Exclude everything that isn't
# needed in the image build to keep the context small.
.git
.github
.claude
.cursor
.gitignore
adr/
bin/
doc/
docs/
dotfiles/
envs/
tests/
README.md
CLAUDE.md
Makefile
renovate.json
renovate-base.json
