{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>igou-io/igou-devenv//renovate-base.json"
  ],
  "ansible-galaxy": {
    "managerFilePatterns": [
      "/(^|/)(galaxy|requirements|galaxy-requirements)(\\.ansible)?\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["pip_requirements"],
      "groupName": "python dependencies"
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "container base images"
    },
    {
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["quay.io/centos/centos"],
      "pinDigests": false
    },
    {
      "matchManagers": ["custom.regex"],
      "groupName": "cli tools"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies"
    },
    {
      "matchManagers": ["mise"],
      "groupName": "mise-managed cli tools"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["jdx/mise"],
      "groupName": "mise itself (trust anchor)"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["aquaproj/aqua-registry"],
      "groupName": "aqua-registry SHA pin (trust anchor)"
    }
  ],
  "customManagers": [
    {
      "description": "Update pinned versions in shell scripts and Dockerfiles via '# renovate:' comments",
      "customType": "regex",
      "managerFilePatterns": ["/\\.sh$/", "/Dockerfile$/", "/Containerfile$/", "/mise\\.toml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?\\n(?:ARG )?\\w+_VERSION=\"(?<currentValue>[^\"]+)\"",
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?\\n(?:ARG )?\\w+_VERSION=\"(?<currentValue>[^\"]+)\"\\n(?:ARG )?\\w+_SHA256_AMD64=\"(?<currentDigest>[a-f0-9]+)\""
      ],
      "versioningTemplate": "semver"
    }
  ]
}
