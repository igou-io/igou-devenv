ARG BASE_IMAGE=agent-base
ARG UBI_IMAGE=registry.access.redhat.com/ubi10/ubi:latest@sha256:c9c81d3d11bfd56c4bb61a220d4598392b5fbc500df33f2b8e52fdd2cebb4944

FROM ${BASE_IMAGE} AS base

# ---------------------------------------------------------------------------
# Build stage — Cursor agent CLI
# ---------------------------------------------------------------------------
FROM ${UBI_IMAGE} AS build

RUN groupadd -g 1000 igou 2>/dev/null || true && \
    useradd -m -u 1000 -g 1000 igou 2>/dev/null || true

# Cursor agent CLI
USER 1000
RUN curl -fsSL https://cursor.com/install | bash && \
    ~/.local/bin/agent --version
USER root

# ---------------------------------------------------------------------------
# Final image from base
# ---------------------------------------------------------------------------
FROM base
USER root

# Cursor agent binary and runtime (bin/ contains symlinks into share/)
COPY --from=build /home/igou/.local/bin /home/igou/.local/bin
COPY --from=build /home/igou/.local/share /home/igou/.local/share
RUN chmod 555 /home/igou/.local/bin && \
    chown -R 1000:1000 /home/igou/.local

# Cursor home and config directories
RUN mkdir -p /home/igou/.config/cursor && \
    chown -R 1000:1000 /home/igou/.config

# Baked sandbox config
RUN mkdir -p /etc/cursor
COPY sandbox.json /etc/cursor/sandbox.json

# Entrypoint
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER 1000
ENTRYPOINT ["entrypoint.sh"]
CMD ["agent"]
