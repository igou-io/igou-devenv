ARG BASE_IMAGE=agent-base
ARG UBI_IMAGE=registry.access.redhat.com/ubi10/ubi:latest@sha256:c9c81d3d11bfd56c4bb61a220d4598392b5fbc500df33f2b8e52fdd2cebb4944

FROM ${BASE_IMAGE} AS base

# ---------------------------------------------------------------------------
# Build stage — Claude Code CLI and seccomp filter
# ---------------------------------------------------------------------------
FROM ${UBI_IMAGE} AS build

RUN dnf install -y nodejs-npm

RUN groupadd -g 1000 igou 2>/dev/null || true && \
    useradd -m -u 1000 -g 1000 igou 2>/dev/null || true

# Claude Code CLI
USER 1000
RUN curl -fsSL https://claude.ai/install.sh | bash && \
    ~/.local/bin/claude --version
USER root

# Seccomp filter for Claude Code sandbox (blocks unix domain sockets).
# Version pinned in package.json, managed by Renovate's native npm manager.
COPY package.json /tmp/sandbox/package.json
RUN set -eux; \
    UARCH=$(uname -m); \
    case "$UARCH" in x86_64) SECCOMP_ARCH=x64;; aarch64) SECCOMP_ARCH=arm64;; *) SECCOMP_ARCH=$UARCH;; esac; \
    SANDBOX_DIR=/opt/claude-sandbox; \
    mkdir -p "$SANDBOX_DIR"; \
    cd /tmp/sandbox && npm install --no-save 2>/dev/null && \
    cp "node_modules/@anthropic-ai/sandbox-runtime/vendor/seccomp/${SECCOMP_ARCH}/unix-block.bpf" "$SANDBOX_DIR/" && \
    cp "node_modules/@anthropic-ai/sandbox-runtime/vendor/seccomp/${SECCOMP_ARCH}/apply-seccomp" "$SANDBOX_DIR/" && \
    chmod +x "$SANDBOX_DIR/apply-seccomp"

# ---------------------------------------------------------------------------
# Final image from base
# ---------------------------------------------------------------------------
FROM base
USER root

# Claude Code binary and dependencies
COPY --from=build /home/igou/.local/bin /home/igou/.local/bin
COPY --from=build /home/igou/.local/share /home/igou/.local/share
RUN chmod 555 /home/igou/.local/bin

# Seccomp filter
COPY --from=build /opt/claude-sandbox/ /usr/local/lib/claude-sandbox/

# Claude home directory
RUN mkdir -p /home/igou/.claude && \
    chown -R 1000:1000 /home/igou/.claude /home/igou/.local

# Baked configs: MCP servers, sandbox settings, global CLAUDE.md
RUN mkdir -p /etc/claude
COPY claude.json /etc/claude/claude.json
COPY settings.json /etc/claude/settings.json
COPY CLAUDE.md /etc/claude/CLAUDE.md

# Config merge script (used by entrypoint to merge baked + user configs)
RUN mkdir -p /usr/local/lib/claude-container
COPY merge-config.py /usr/local/lib/claude-container/merge-config.py

# Entrypoint
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER 1000
ENTRYPOINT ["entrypoint.sh"]
CMD ["claude"]
