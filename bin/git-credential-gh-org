#!/usr/bin/env bash
# git credential helper: per-org GitHub token selection from environment vars.
#
# Git invokes this as `git-credential-gh-org <operation>` and feeds the request
# (protocol/host/path) on stdin. We only answer `get`, and only for github.com.
#
# Token selection (first match wins):
#   1. GH_TOKEN_<ORG>   — org is the first path segment, upper-cased, with any
#                         non-alphanumeric char folded to `_` (e.g. the repo
#                         github.com/igou-io/foo  ->  $GH_TOKEN_IGOU_IO).
#                         Requires `credential.useHttpPath = true` (set by
#                         .devcontainer/setup-git-credentials.sh).
#   2. GH_TOKEN         — single fallback token for any org.
#   3. GITHUB_TOKEN     — last-resort fallback (matches the gh CLI convention).
#
# To switch the token for an org, just re-export its var — nothing is cached or
# written to disk. `store`/`erase` are no-ops so the token never leaves the env.
set -euo pipefail

[ "${1:-}" = "get" ] || exit 0

# Parse the key=value request from stdin (blank line terminates).
declare -A req=()
while IFS='=' read -r key value; do
    [ -z "$key" ] && break
    req["$key"]="$value"
done

# Only handle github.com over https.
[ "${req[host]:-}" = "github.com" ] || exit 0

# Derive the org from the first path segment when useHttpPath gave us one.
token=""
path="${req[path]:-}"
org="${path%%/*}"
if [ -n "$org" ]; then
    var="GH_TOKEN_$(printf '%s' "$org" | tr '[:lower:]-' '[:upper:]_' | tr -cd 'A-Z0-9_')"
    token="${!var:-}"
fi

# Fall back to a single global token, then the gh-CLI-style var.
token="${token:-${GH_TOKEN:-${GITHUB_TOKEN:-}}}"

# No token found — stay silent so git can try other helpers or fail cleanly.
[ -n "$token" ] || exit 0

printf 'username=x-access-token\n'
printf 'password=%s\n' "$token"
